# Public Convex deployment URL used by the browser client.
NEXT_PUBLIC_CONVEX_URL=

# Server-side Convex URL. If omitted, the app falls back to NEXT_PUBLIC_CONVEX_URL.
CONVEX_URL=

# Convex HTTP actions site URL. If omitted, the app infers it from CONVEX_URL.
CONVEX_SITE_URL=

# Shared manual-ingestion token. Set the same value in Vercel and Convex.
INGEST_TOKEN=
